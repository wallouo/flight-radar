{
  "name": "flight-price-radar",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test dist/**/*.test.js",
    "init:database": "node dist/scripts/init-database.js",
    "seed:tracked-destinations": "node dist/scripts/seed-tracked-destinations.js",
    "sync:tracked-destinations": "node dist/scripts/sync-tracked-destinations.js",
    "bootstrap:fare-history": "node dist/scripts/bootstrap-fare-history.js",
    "test:rss-live": "npm run build && node dist/scripts/test-rss-live.js",
    "test:rss-curl": "npm run build && node dist/scripts/test-rss-curl.js",
    "test:secretflying-pipeline": "npm run build && node dist/scripts/test-secretflying-pipeline.js",
    "job:business-deals": "node dist/scripts/run-business-deals.js",
    "job:normal-fares": "node dist/scripts/run-normal-fares.js",
    "update:exchange-rates": "node dist/scripts/update-exchange-rates.js",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.7.1",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3"
  }
}
