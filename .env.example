NODE_ENV=development

# Database
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=your-database-auth-token

# Optional aliases. If set, these override DATABASE_URL and DATABASE_AUTH_TOKEN.
# TURSO_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-database-auth-token

# Flight search — SerpAPI keys
# Option A: single key (legacy)
SERPAPI_API_KEY=your-serpapi-api-key
# Option B: comma-separated pool (recommended if you have multiple keys).
# The pool auto-rotates to the next key when one hits its monthly limit (HTTP 429).
# If set, this takes precedence over SERPAPI_API_KEY.
# SERPAPI_API_KEYS=key1,key2,key3

# LLM extraction for business deals
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# GROQ_API_KEY=

# RSS feeds for business deals. Use comma-separated values.
# Format: url OR name|url
RSS_FEED_URLS=SecretFlying|https://example.com/feed.xml,PremiumDeals|https://example.com/another-feed.xml

# Discord notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Business deal alert threshold
BUSINESS_DEAL_THRESHOLD_GBP=1000
BUSINESS_DEAL_MIN_CONFIDENCE=0.8

# Schedules
# normal-fares: every 12h by default (Phase 1 calendar = 1 call/destination, very cheap)
# Bump to "0 */6 * * *" if you have a paid SerpAPI plan and want faster alerts.
NORMAL_FARES_CRON=0 */12 * * *
BUSINESS_DEALS_CRON=0 */2 * * *
RUN_NORMAL_FARES_ON_STARTUP=true
RUN_BUSINESS_DEALS_ON_STARTUP=true
SCHEDULER_LEASE_DURATION_MS=1800000
